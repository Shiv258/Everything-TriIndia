generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  WALK_IN
  BOOKING_COM
  MMT
  KALAKAR
  OTHER
}

model Property {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  address   String
  city      String
  phone     String
  rooms     Room[]
  bookings  Booking[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Room {
  id          String     @id @default(cuid())
  propertyId  String
  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  baseRate    Int
  capacity    Int
  description String
  bookings    Booking[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([propertyId, slug])
}

model Guest {
  id        String    @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([phone])
}

model Kalakar {
  id        String    @id @default(cuid())
  name      String
  phone     String?
  active    Boolean   @default(true)
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Booking {
  id              String        @id @default(cuid())
  reference       String        @unique
  propertyId      String
  property        Property      @relation(fields: [propertyId], references: [id])
  roomId          String?
  room            Room?         @relation(fields: [roomId], references: [id])
  guestId         String
  guest           Guest         @relation(fields: [guestId], references: [id])
  kalakarId       String?
  kalakar         Kalakar?      @relation(fields: [kalakarId], references: [id])
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  source          LeadSource    @default(WEBSITE)
  status          BookingStatus @default(NEW)
  paymentStatus   PaymentStatus @default(PENDING)
  estimatedAmount Int?
  specialRequests String?
  payments        Payment[]
  messages        Message[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([propertyId, checkIn, checkOut])
  @@index([status])
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider          String        @default("razorpay")
  providerPaymentId String?
  amount            Int
  status            PaymentStatus @default(PENDING)
  rawPayload         Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Message {
  id          String   @id @default(cuid())
  bookingId   String?
  booking     Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  direction   String
  channel     String   @default("whatsapp")
  phone       String
  body        String
  providerId  String?
  rawPayload  Json?
  createdAt   DateTime @default(now())
}
