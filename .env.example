# TriIndia Hospitality — environment variables
#
# Copy this file to `.env` and fill in real values. Get the real values from
# Shiv via the private Gist link he shared in WhatsApp / Signal.
#
# NEVER commit `.env` to git. `.gitignore` already excludes it; don't override.

# ─── Database (Next.js + Prisma) ─────────────────────────────────────────────
# Local default points at the docker-compose.local.yml Postgres.
# Production points at the Contabo Postgres (different password).
DATABASE_URL="postgresql://triindia:triindia_local_password@localhost:5432/triindia_hospitality?schema=public"

# ─── Mapbox (Delhi hotels map on the home page) ──────────────────────────────
# pk.* token is the PUBLIC token used by the browser to render the map.
# Restrict it by URL in the Mapbox dashboard (triindiahospitality.com + localhost).
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ─── Razorpay (payment gateway — Phase 2.X) ──────────────────────────────────
# Get from https://dashboard.razorpay.com → API Keys. Use TEST keys for dev.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ─── WhatsApp (BSP for guest comms — Phase 2.X) ──────────────────────────────
# Provider choice between AiSensy and Wati. Switching providers means swapping
# the credentials below; keep the variable names stable.
WHATSAPP_PROVIDER="aisensy"
WHATSAPP_API_KEY=""
WHATSAPP_WEBHOOK_SECRET=""

# ─── AI provider (Claude or GPT-4o for the WhatsApp agent — Phase 2.X) ───────
AI_PROVIDER="openai"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ─── Odoo CRM (already live; OCR app pushes leads via XML-RPC) ───────────────
# These are also used by the future glue service.
# Important: ODOO_DB is case-sensitive. The correct value is `TriIndia_Hospitality`,
# NOT `triindia` (that mistake caused a 403 in production once).
ODOO_URL="https://crm.triindiahospitality.com"
ODOO_DB="TriIndia_Hospitality"
ODOO_USERNAME=""
ODOO_API_KEY=""
ODOO_SYNC_ENABLED="true"

# ─── QloApps PMS (Webservice API — Stage 2 of the QloApps plan) ──────────────
# Once Stage 2 in docs/ai-onboarding/plans/website-and-qloapps-plan.md is done,
# fill these in. The API key is created in QloApps admin → Advanced Parameters
# → Webservice. Use it as HTTP Basic auth USERNAME with empty password.
QLOAPPS_URL="https://book.triindiahospitality.com"
QLOAPPS_API_KEY=""

# ─── FAL.AI (for video generation, optional) ─────────────────────────────────
# Used during Seedance hero video creation. Not required for day-to-day work.
FAL_KEY=""
